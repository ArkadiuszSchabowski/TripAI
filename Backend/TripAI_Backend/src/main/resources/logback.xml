<configuration>
    <appender name="ERROR" class="ch.qos.logback.core.FileAppender">
        <file>TripAI_Backend/logs/error_logs.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} | %-5level | ---------------------------------------------------------------------------------------------- |%n%n%logger | %msg %ex%n</pattern>
        </encoder>
    </appender>

    <root level="error">
        <appender-ref ref="ERROR" />
    </root>
</configuration>